{{#*inline "body"}}
<div class="content-area">
<main class="site-main">

    {{#with post}}

    <article class="{{post_class}}{{#unless feature_image}} no-image{{/unless}} single-post">

        <header class="article-header gh-canvas">
            <div class="post-meta">
                <span class="post-meta-item post-meta-date">
                    <time datetime="{{date published_at format="YYYY-MM-DD"}}">{{date published_at format="DD MMM YYYY"}}</time>
                </span>
                {{#if reading_time}}
                    <span class="post-meta-item post-meta-length">{{reading_time}}</span>
                {{/if}}
                {{#if @root.site.comments_enabled}}
                    {{comment_count class="post-meta-item"}}
                {{/if}}
                {{#with primary_tag}}
                    <span class="post-meta-item post-meta-tags"><a class="post-tag post-tag-{{slug}}" href="/{{slug}}" title="{{name}}">{{name}}</a></span>
                {{/with}}
            </div>
            <h1 class="post-title">{{title}}</h1>
            {{> partials/post-image}}
        </header>

        <div class="gh-content gh-canvas">
            {{{content}}}
        </div>

        {{#if @root.custom.show_author}}
            {{> partials/author-box}}
        {{/if}}

    </article>

    {{#if comments}}
        <section class="gh-comments gh-canvas">
            <h3 class="related-title">Comments ({{comment_count empty="0" singular="" plural=""}})</h3>
            {{comments title="" count=false}}
        </section>
    {{/if}}

    {{#if @root.custom.show_related_posts}}
        {{> partials/related}}
    {{/if}}

    {{/with}}

</main>
</div>
{{/inline}}
{{> default}}